    "url": "https://github.com/go-to-k/cdk-real-drift/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "keywords": [
    "cdk",
    "cloudformation",
    "drift",
    "aws",
    "iac",
    "undeclared",
    "developer-tools"
  ],
  "author": {
    "name": "go-to-k",
    "url": "https://github.com/go-to-k"
  },
  "license": "Apache-2.0",
  "engines": {
