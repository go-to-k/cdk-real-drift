{
  "name": "cdk-real-drift",
  "version": "0.0.0",
  "description": "Detect when real AWS resources drift from your AWS CDK app - including UNDECLARED properties that cdk drift / CloudFormation drift detection never see.",
  "bin": {
    "cdkrd": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
