      "MasterUserPassword": "not-a-real-secret",
      "Port": 5439
    }
  },
  "liveRaw": {
    "NodeType": "dc2.large"
  },
  "schema": {
    "readOnly": [],
    "writeOnly": ["MasterUserPassword"],
    "createOnly": [],
    "readOnlyPaths": [],
    "writeOnlyPaths": ["MasterUserPassword"],
    "createOnlyPaths": [],
    "defaults": {}
  },
  "opts": {
    "accountId": "111111111111",
    "region": "us-east-1",
    "kmsAliasTargets": {}
  },
  "expected": [
    {
      "tier": "readGap",
